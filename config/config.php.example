// --- URLs base (sin barra final) ---
define('SITE_BASE_URL', 'https://chichalabs.studio');
define('PORTAL_BASE_URL', 'https://chichalabs.studio/portal');
define('ADMIN_BASE_URL', 'https://chichalabs.studio/admin');

// --- n8n (opcional) — dejar vacío para desactivar la notificación ---
define('N8N_PROPOSAL_ACCEPTED_WEBHOOK', '');

// --- Entorno ---
// 'local' muestra errores detallados; cualquier otro valor los oculta (producción).
define('APP_ENV', 'production');

if (APP_ENV === 'local') {
    ini_set('display_errors', '1');
    error_reporting(E_ALL);
} else {
    ini_set('display_errors', '0');
    error_reporting(E_ALL);
}
