// --- SMTP (hPanel → Correos → cuenta de correo del dominio) ---
define('SMTP_HOST', 'smtp.hostinger.com');
define('SMTP_PORT', 465); // 465 = SMTPS implícito, 587 = STARTTLS
define('SMTP_USER', 'notificaciones@chichalabs.studio');
define('SMTP_PASS', 'CAMBIAR_ESTO');
